    "# ===================== BOOTSTRAP OFFLINE (RUN ALL - KAGGLE) =====================\n",
    "import os\n",
    "import sys\n",
    "import glob\n",
    "import tempfile\n",
    "from pathlib import Path\n",
    "\n",
    "IS_KAGGLE = Path('/kaggle').exists()\n",
    "\n",
    "# Diretórios oficiais solicitados para datasets Kaggle anexados.\n",
    "OFFICIAL_KAGGLE_ADAPTERS_ROOT = '/kaggle/input/datasets/cesaraugusto1156156/adapters-lora/aimo3-lora-adapters'\n",
    "OFFICIAL_KAGGLE_UTILS_ROOT = '/kaggle/input/datasets/cesaraugusto1156156/utils3aimo/aimo-3-utils'\n",
    "\n",
    "os.environ.setdefault('AIMO3_OFFICIAL_UTILS_ROOT', OFFICIAL_KAGGLE_UTILS_ROOT)\n",
    "os.environ.setdefault('AIMO3_OFFICIAL_ADAPTERS_ROOT', OFFICIAL_KAGGLE_ADAPTERS_ROOT)\n",
    "\n",
    "\n",
    "def _pick_first_existing(candidates: list[str]) -> str | None:\n",
    "    \"\"\"Retorna o primeiro caminho existente da lista (ou None).\"\"\"\n",
    "    for candidate in candidates:\n",
    "        if candidate and os.path.exists(candidate):\n",
    "            return candidate\n",
    "    return None\n",
    "\n",
    "\n",
    "def _is_placeholder_lora_path(candidate: str | None) -> bool:\n",
    "    normalized = (candidate or '').strip()\n",
    "    return normalized in {\n",
    "        '',\n",
    "        '/kaggle/input/SEU_DATASET_LORA/aimo3_lora',\n",
    "        'SEU_DATASET_LORA',\n",
    "    }\n",
    "\n",
    "\n",
    "def _looks_like_lora_adapter_dir(candidate: str | None) -> bool:\n",
    "    if not candidate or not os.path.isdir(candidate):\n",
    "        return False\n",
    "    has_adapter_config = os.path.exists(os.path.join(candidate, 'adapter_config.json'))\n",
    "    has_adapter_weights = bool(glob.glob(os.path.join(candidate, 'adapter_model*')))\n",
    "    return bool(has_adapter_config or has_adapter_weights)\n",
    "\n",
    "\n",
    "def _expand_lora_candidates(path: str, adapter_name: str) -> list[str]:\n",
    "    normalized = (path or '').strip()\n",
    "    if not normalized:\n",
    "        return []\n",
    "\n",
    "    expanded = [normalized]\n",
    "    expanded.append(os.path.join(normalized, adapter_name))\n",
    "    expanded.append(os.path.join(normalized, adapter_name.replace('_', '-')))\n",
    "\n",
    "    if os.path.isdir(normalized):\n",
    "        expanded.extend(sorted(glob.glob(os.path.join(normalized, '*'))))\n",
    "        expanded.extend(sorted(glob.glob(os.path.join(normalized, '*', '*'))))\n",
    "\n",
    "    return expanded\n",
    "\n",
    "\n",
    "def _discover_wheels_archive() -> str | None:\n",
    "    \"\"\"Descobre automaticamente o archive de wheels no Kaggle/input.\"\"\"\n",
    "    explicit = os.getenv('AIMO3_WHEELS_ARCHIVE')\n",
    "    if explicit and os.path.exists(explicit):\n",
    "        return explicit\n",
    "\n",
    "    direct_candidates = [\n",
    "        os.path.join(os.getenv('AIMO3_OFFICIAL_UTILS_ROOT', OFFICIAL_KAGGLE_UTILS_ROOT), 'wheels.tar.gz'),\n",
    "        '/kaggle/input/aimo-3-utils/wheels.tar.gz',\n",
    "    ]\n",
    "    for candidate in direct_candidates:\n",
    "        if candidate and os.path.exists(candidate):\n",
    "            return candidate\n",
    "\n",
    "    patterns = [\n",
    "        '/kaggle/input/*/wheels.tar.gz',\n",
    "        '/kaggle/input/*/*/wheels.tar.gz',\n",
    "    ]\n",
    "\n",
    "    for pattern in patterns:\n",
    "        matches = sorted(glob.glob(pattern))\n",
    "        if matches:\n",
    "            return matches[0]\n",
    "\n",
    "    return None\n",
    "\n",
    "\n",
    "def _discover_local_lora_adapter() -> tuple[str | None, str]:\n",
    "    \"\"\"Descobre um adapter LoRA local válido priorizando paths oficiais Kaggle.\"\"\"\n",
    "    adapter_name = (os.getenv('AIMO3_LORA_ADAPTER_NAME') or 'aimo3_lora').strip() or 'aimo3_lora'\n",
    "    explicit_path = (os.getenv('AIMO3_LORA_ADAPTER_PATH') or '').strip()\n",
    "    configured_dir = (os.getenv('AIMO3_LORA_ADAPTER_DIR') or '').strip()\n",
    "    official_adapters_root = os.getenv('AIMO3_OFFICIAL_ADAPTERS_ROOT', OFFICIAL_KAGGLE_ADAPTERS_ROOT)\n",
    "\n",
    "    candidates: list[tuple[str, str]] = []\n",
    "    if explicit_path and not _is_placeholder_lora_path(explicit_path):\n",
    "        candidates.append(('AIMO3_LORA_ADAPTER_PATH', explicit_path))\n",
    "    if configured_dir:\n",
    "        candidates.append(('AIMO3_LORA_ADAPTER_DIR', configured_dir))\n",
    "        candidates.append(('AIMO3_LORA_ADAPTER_DIR + adapter_name', os.path.join(configured_dir, adapter_name)))\n",
    "\n",
    "    static_candidates = [\n",
    "        official_adapters_root,\n",
    "        os.path.join(official_adapters_root, adapter_name),\n",
    "        os.path.join(official_adapters_root, adapter_name.replace('_', '-')),\n",
    "        '/kaggle/input/aimo3-lora-adapters',\n",
    "        f'/kaggle/input/aimo3-lora-adapters/{adapter_name}',\n",
    "        '/kaggle/input/aimo3-math-adapter',\n",
    "        f'/kaggle/input/aimo3-math-adapter/{adapter_name}',\n",
    "        '/kaggle/working/aimo3_lora_adapters',\n",
    "        f'/kaggle/working/aimo3_lora_adapters/{adapter_name}',\n",
    "        '/kaggle/working/aimo3_lora_merged',\n",
    "    ]\n",
    "    for candidate in static_candidates:\n",
    "        candidates.append(('static_hint', candidate))\n",
    "\n",
    "    if IS_KAGGLE:\n",
    "        patterns = [\n",
    "            f'/kaggle/input/*/{adapter_name}',\n",
    "            f'/kaggle/input/*/*/{adapter_name}',\n",
    "            '/kaggle/input/*lora*',\n",
    "            '/kaggle/input/*adapter*',\n",
    "            '/kaggle/input/*/*lora*',\n",
    "            '/kaggle/input/*/*adapter*',\n",
    "            '/kaggle/input/*/*/*lora*',\n",
    "            '/kaggle/input/*/*/*adapter*',\n",
    "            '/kaggle/working/*lora*',\n",
    "            '/kaggle/working/*adapter*',\n",
    "            '/kaggle/working/*/*lora*',\n",
    "            '/kaggle/working/*/*adapter*',\n",
    "        ]\n",
    "        for pattern in patterns:\n",
    "            for match in sorted(glob.glob(pattern)):\n",
    "                candidates.append((pattern, match))\n",
    "\n",
    "    seen = set()\n",
    "    for source, candidate in candidates:\n",
    "        for expanded in _expand_lora_candidates(candidate, adapter_name):\n",
    "            key = expanded.strip().lower()\n",
    "            if not key or key in seen:\n",
    "                continue\n",
    "            seen.add(key)\n",
    "            if _looks_like_lora_adapter_dir(expanded):\n",
    "                return expanded, source\n",
    "\n",
    "    return None, 'not_found'\n",
    "\n",
    "\n",
    "OFFLINE_PATHS = {}\n",
    "OFFLINE_PATHS['setup_dir'] = os.getenv(\n",
    "    'AIMO3_SETUP_DIR',\n",
    "    '/kaggle/tmp/setup' if IS_KAGGLE else os.path.join(tempfile.gettempdir(), 'aimo3_setup'),\n",
    ")\n",
    "\n",
    "OFFLINE_PATHS['utils_root'] = _pick_first_existing([\n",
    "    os.getenv('AIMO3_UTILS_ROOT', ''),\n",
    "    os.getenv('AIMO3_OFFICIAL_UTILS_ROOT', OFFICIAL_KAGGLE_UTILS_ROOT),\n",
    "    '/kaggle/input/aimo-3-utils',\n",
    "])\n",
    "\n",
    "OFFLINE_PATHS['wheels_archive'] = _discover_wheels_archive()\n",
    "OFFLINE_PATHS['wheels_dir'] = _pick_first_existing([\n",
    "    os.getenv('AIMO3_WHEELS_DIR', ''),\n",
    "    os.path.join(OFFLINE_PATHS['utils_root'], 'wheels') if OFFLINE_PATHS.get('utils_root') else '',\n",
    "    '/kaggle/input/aimo-3-utils/wheels',\n",
    "])\n",
    "\n",
    "OFFLINE_PATHS['model_path'] = _pick_first_existing([\n",
    "    os.getenv('AIMO3_MODEL_PATH', ''),\n",
    "    '/kaggle/input/gpt-oss-120b/transformers/default/1',\n",
    "    '/kaggle/input/gpt-oss-20b/transformers/default/1',\n",
    "    '/kaggle/working/models/gpt-oss-120b',\n",
    "])\n",
    "\n",
    "OFFLINE_PATHS['reference_csv'] = _pick_first_existing([\n",
    "    os.getenv('AIMO3_REFERENCE_CSV', ''),\n",
    "    '/kaggle/input/ai-mathematical-olympiad-progress-prize-3/reference.csv',\n",
    "    '/kaggle/working/reference.csv',\n",
    "])\n",
    "\n",
    "OFFLINE_PATHS['lora_adapter_path'], OFFLINE_PATHS['lora_adapter_source'] = _discover_local_lora_adapter()\n",
    "\n",
    "# Sinalizadores offline para evitar acesso à internet no Run All.\n",
    "os.environ.setdefault('HF_HUB_OFFLINE', '1')\n",
    "os.environ.setdefault('TRANSFORMERS_OFFLINE', '1')\n",
    "os.environ.setdefault('PIP_NO_INDEX', '1')\n",
    "os.environ.setdefault('PIP_DISABLE_PIP_VERSION_CHECK', '1')\n",
    "\n",
    "if OFFLINE_PATHS['model_path'] is not None:\n",
    "    os.environ['AIMO3_MODEL_PATH'] = OFFLINE_PATHS['model_path']\n",
    "if OFFLINE_PATHS['reference_csv'] is not None:\n",
    "    os.environ['AIMO3_REFERENCE_CSV'] = OFFLINE_PATHS['reference_csv']\n",
    "if OFFLINE_PATHS.get('utils_root'):\n",
    "    os.environ.setdefault('AIMO3_UTILS_ROOT', OFFLINE_PATHS['utils_root'])\n",
    "\n",
    "_existing_lora_path = (os.getenv('AIMO3_LORA_ADAPTER_PATH') or '').strip()\n",
    "if OFFLINE_PATHS['lora_adapter_path'] and _is_placeholder_lora_path(_existing_lora_path):\n",
    "    os.environ['AIMO3_LORA_ADAPTER_PATH'] = OFFLINE_PATHS['lora_adapter_path']\n",
    "\n",
    "print('[BOOTSTRAP] Offline bootstrap inicializado')\n",
    "print(f\"[BOOTSTRAP] IS_KAGGLE={IS_KAGGLE}\")\n",
    "print(f\"[BOOTSTRAP] setup_dir={OFFLINE_PATHS['setup_dir']}\")\n",
    "print(f\"[BOOTSTRAP] utils_root={OFFLINE_PATHS.get('utils_root')}\")\n",
    "print(f\"[BOOTSTRAP] wheels_archive={OFFLINE_PATHS['wheels_archive']}\")\n",
    "print(f\"[BOOTSTRAP] wheels_dir_hint={OFFLINE_PATHS['wheels_dir']}\")\n",
    "print(f\"[BOOTSTRAP] model_path={OFFLINE_PATHS['model_path']}\")\n",
    "print(f\"[BOOTSTRAP] reference_csv={OFFLINE_PATHS['reference_csv']}\")\n",
    "print(f\"[BOOTSTRAP] lora_adapter_path={OFFLINE_PATHS['lora_adapter_path']}\")\n",
    "print(f\"[BOOTSTRAP] lora_adapter_source={OFFLINE_PATHS['lora_adapter_source']}\")"
   ]
