    "# ===================== PATCH: RESILIENT KERNEL INITIALIZATION =====================\n",
    "def _resilient_initialize_kernels(self) -> None:\n",
    "    \"\"\"Inicializa kernels com timeout/retry e degradação graciosa em vez de crash total.\"\"\"\n",
    "    target_workers = max(1, int(getattr(self.cfg, 'workers', 16)))\n",
    "    boot_workers = max(1, min(target_workers, int(getattr(self.cfg, 'kernel_boot_workers', 4))))\n",
    "    boot_retries = max(1, int(getattr(self.cfg, 'kernel_boot_retries', 3)))\n",
    "    boot_timeout = max(float(getattr(self.cfg, 'kernel_boot_timeout', getattr(self.cfg, 'jupyter_timeout', 20))), 10.0)\n",
    "\n",
    "    print(\n",
    "        f\"Initializing {target_workers} persistent Jupyter kernels \"\n",
    "        f\"(boot_workers={boot_workers}, retries={boot_retries}, timeout={boot_timeout}s)...\"\n",
    "    )\n",
    "    start_time = time.time()\n",
    "\n",
    "    self.sandbox_pool = queue.Queue()\n",
    "\n",
    "    def _create_sandbox_with_retries(worker_idx: int) -> AIMO3Sandbox:\n",
    "        last_exc = None\n",
    "        for attempt in range(1, boot_retries + 1):\n",
    "            try:\n",
    "                return AIMO3Sandbox(timeout=boot_timeout)\n",
    "            except Exception as exc:\n",
    "                last_exc = exc\n",
    "                print(\n",
    "                    f\"[KERNEL][WARN] worker={worker_idx} tentativa={attempt}/{boot_retries} falhou: {exc}\"\n",
    "                )\n",
    "                time.sleep(min(2.0, 0.3 * attempt))\n",
    "        raise RuntimeError(\n",
    "            f\"[KERNEL][FAIL] worker={worker_idx} não inicializou após {boot_retries} tentativas. \"\n",
    "            f\"Último erro: {last_exc}\"\n",
    "        )\n",
    "\n",
    "    successes = 0\n",
    "    failures = []\n",
    "\n",
    "    with ThreadPoolExecutor(max_workers=boot_workers) as executor:\n",
    "        futures = {\n",
    "            executor.submit(_create_sandbox_with_retries, idx): idx\n",
    "            for idx in range(target_workers)\n",
    "        }\n",
    "        for future in as_completed(futures):\n",
    "            idx = futures[future]\n",
    "            try:\n",
    "                sandbox = future.result()\n",
    "                self.sandbox_pool.put(sandbox)\n",
    "                successes += 1\n",
    "            except Exception as exc:\n",
    "                failures.append((idx, str(exc)))\n",
    "\n",
    "    if successes == 0:\n",
    "        raise RuntimeError(\n",
    "            '[KERNEL][FATAL] Nenhum sandbox Jupyter inicializou. '\n",
    "            'Aumente AIMO3_JUPYTER_TIMEOUT/AIMO3_KERNEL_BOOT_TIMEOUT e reduza AIMO3_KERNEL_BOOT_WORKERS.'\n",
    "        )\n",
    "\n",
    "    # Degrada para a capacidade real disponível, evitando quebra total do solver.\n",
    "    self.cfg.workers = int(successes)\n",
    "    if int(getattr(self.cfg, 'attempts', 8)) > successes:\n",
    "        self.cfg.attempts = max(successes, int(getattr(self.cfg, 'early_stop', 4)))\n",
    "\n",
    "    elapsed = time.time() - start_time\n",
    "    print(\n",
    "        f\"Kernels initialized: {successes}/{target_workers} in {elapsed:.2f}s. \"\n",
    "        f\"workers efetivos={self.cfg.workers} | attempts ajustados={self.cfg.attempts}\"\n",
    "    )\n",
    "\n",
    "    if failures:\n",
    "        print('[KERNEL][INFO] Falhas de bootstrap detectadas (resumo):')\n",
    "        for idx, msg in failures[:6]:\n",
    "            print(f\"  - worker={idx}: {msg}\")\n",
    "\n",
    "\n",
    "AIMO3Solver._initialize_kernels = _resilient_initialize_kernels\n",
    "print('[PATCH] AIMO3Solver._initialize_kernels atualizado para modo resiliente (offline-safe).')\n"
