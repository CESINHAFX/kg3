    "\n",
    "                futures.append(future)\n",
    "\n",
    "            for future in as_completed(futures):\n",
    "                try:\n",
    "                    result = future.result()\n",
    "                    detailed_results.append(result)\n",
    "\n",
    "                    if result['Answer'] is not None:\n",
