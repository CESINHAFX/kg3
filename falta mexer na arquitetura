xception as e:\n        print(f\"{pkg}: NOT FOUND ({e})\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-08T08:45:00.072045Z","iopub.execute_input":"2026-03-08T08:45:00.072264Z","iopub.status.idle":"2026-03-08T08:45:00.083983Z","shell.execute_reply.started":"2026-03-08T08:45:00.072245Z","shell.execute_reply":"2026-03-08T08:45:00.083555Z"}},"outputs":[{"name":"stdout","text":"bitsandbytes: 0.49.2\naccelerate: 1.13.0\ntransformers: 4.57.1\n","output_type":"stream"}],"execution_count":5},{"id":"1b81a6c7-eaa0-4d89-9bbe-ff11d2fef924","cell_type":"code","source":"# === Inicialização segura do cliente OSS (gpt-oss-120b) ===\nimport os, requests, json\nfrom typing import Optional, Generator\n\nOSS_MODEL_ENDPOINT = os.getenv(\"OSS_MODEL_ENDPOINT\", \"http://localhost:8080/v1/generate\")\nOSS_MODEL_NAME = os.getenv(\"OSS_MODEL_NAME\", \"gpt-oss-120b\")\nOSS_API_KEY = os.getenv(\"OSS_API_KEY\", \"\")\n\nclass OSSModelClient:\n    def __init__(self, endpoint: str = OSS_MODEL_ENDPOINT, model: str = OSS_MODEL_NAME, api_key: str = OSS_API_KEY):\n        self.endpoint = endpoint.rstrip(\"/\")\n        self.model = model\n        self.api_key = api_key\n\n    def _headers(self):\n        h = {\"Content-Type\": \"application/json\"}\n        if self.api_key:\n            h[\"Authorization\"] = f\"Bearer {self.api_key}\"\n        return h\n\n    def generate(self, prompt: str, max_tokens: int = 512, temperature: float = 0.0, stop: Optional[list] = None) -> str:\n        payload = {\"model\": self.model, \"prompt\": prompt, \"max_tokens\": max_tokens, \"temperature\": temperature}\n        if stop:\n            payload[\"stop\"] = stop\n        resp = requests.post(self.endpoint, headers=self._headers(), json=payload, timeout=60)\n        resp.raise_for_status()\n        data = resp.json()\n        if isinstance(data, dict):\n            if \"choices\" in data and data[\"choices\"]:\n                return data[\"choices\"][0].get(\"text\",\"\") or data[\"choices\"][0].get(\"content\",\"\")\n            if \"output\" in data:\n                return data[\"output\"]\n            return json.dumps(data)\n        return str(data)\n\n    def stream(self, prompt: str, max_tokens: int = 512, temperature: float = 0.0) -> Generator[str, None, None]:\n        payload = {\"model\": self.model, \"prompt\": prompt, \"max_tokens\": max_tokens, \"temperature\": temperature}\n        with requests.post(self.endpoint, headers=self._headers(), json=payload, stream=True, timeout=300) as resp:\n            resp.raise_for_status()\n            for chunk in resp.iter_lines(decode_unicode=True):\n                if not chunk:\n                    continue\n                try:\n                    part = json.loads(chunk)\n                    text = part.get(\"text\") or part.get(\"content\") or part.get(\"delta\") or part.get(\"output\")\n                    if text:\n                        yield text\n                    elif \"choices\" in part and part[\"choices\"]:\n                        yield part[\"choices\"][0].get(\"text\",\"\")\n                except json.JSONDecodeError:\n                    yield chunk\n\n# Instanciar cliente global (não sobrescreve se já existir)\nif 'oss_client' not in globals():\n    try:\n        oss_client = OSSModelClient()\n        globals()['oss_client'] = oss_client\n        print(\"OSSModelClient inicializado para\", OSS_MODEL_NAME)\n    except Exception as e:\n        print(\"Falha ao inicializar OSSModelClient:\", str(e))\n\n# Flag de controle\nif 'USE_REAL_OSS' not in globals():\n    globals()['USE_REAL_OSS'] = globals().get('oss_client') is not None\nprint(\"USE_REAL_OSS =\", globals()['USE_REAL_OSS'])\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-08T08:50:09.883775Z","iopub.execute_input":"2026-03-08T08:50:09.884294Z","iopub.status.idle":"2026-03-08T08:50:09.891783Z","shell.execute_reply.started":"2026-03-08T08:50:09.884278Z","shell.execute_reply":"2026-03-08T08:50:09.891384Z"}},"outputs":[{"name":"stdout","text":"USE_REAL_OSS = True\n","output_type":"stream"}],"execution_count":10},{"id":"e4bf1084-c8d0-49b9-b7ac-d494ef9dc554","cell_type":"code","source":"# === Funções de templates / extração (garantia) ===\nimport re\n\ndef extract_answer_from_response(response_text: str) -> str:\n    \"\"\"\n    Heurística robusta para extrair a resposta final do texto gerado:\n    1) procura por um inteiro isolado (ex.: '42')\n    2) procura por padrão 'Answer: ...' ou 'Resposta: ...'\n    3) retorna a primeira linha não vazia como fallback\n    \"\"\"\n    if not response_text:\n        return \"\"\n\n    text = str(response_text).strip()\n\n    # 1) procurar por 'Answer: ...' ou 'Resposta: ...'\n    m = re.search(r'(?:Answer|Resposta)\\s*[:\\-]\\s*(.+)', text, flags=re.IGNORECASE)\n    if m:\n        candidate = m.group(1).strip()\n        # pegar apenas o token inicial se for número\n        num = re.search(r'[-+]?\\d+', candidate)\n        return num.group(0) if num else candidate.splitlines()[0].strip()\n\n    # 2) procurar por inteiro isolado em qualquer lugar\n    num = re.search(r'[-+]?\\d+', text)\n    if num:\n        return num.group(0)\n\n    # 3) fallback: primeira linha não vazia\n    for line in text.splitlines():\n        s = line.strip()\n        if s:\n            return s\n    return text\n\n# Expor no globals para compatibilidade com o restante do notebook\nglobals()['extract_answer_from_response'] = extract_answer_from_response\nprint(\"extract_answer_from_response definida.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-08T08:50:31.169060Z","iopub.execute_input":"2026-03-08T08:50:31.169504Z","iopub.status.idle":"2026-03-08T08:50:31.173628Z","shell.execute_reply.started":"2026-03-08T08:50:31.169481Z","shell.execute_reply":"2026-03-08T08:50:31.173238Z"}},"outputs":[{"name":"stdout","text":"extract_answer_from_response definida.\n","output_type":"stream"}],"execution_count":11},{"id":"fa076480-2548-4923-8385-9cddc0f54a6f","cell_type":"code","source":"# === Garantia de prepare_test_prompt ===\nimport textwrap\n\nif 'prepare_test_prompt' in globals():\n    print(\"prepare_test_prompt já definida — mantendo implementação existente.\")\nelse:\n    def prepare_test_prompt(problem: str, context_text: str = \"\", template_type: str = \"simple\") -> str:\n        \"\"\"\n        Versão compatível de prepare_test_prompt usada nos testes.\n        - template_type 'simple' -> prompt enxuto com instrução direta.\n        - template_type 'with_context' -> inclui contexto antes do enunciado.\n        Mantém formato legível e curto para evitar estouro de tokens.\n        \"\"\"\n        problem = (problem or \"\").strip()\n        context_text = (context_text or \"\").strip()\n\n        if template_type == \"with_context\" and context_text:\n            # Limitar contexto a 1200 caracteres para segurança\n            ctx = context_text if len(context_text) <= 1200 else context_text[:1200] + \"...\"\n            prompt = textwrap.dedent(f\"\"\"\n                Use the following context to help solve the problem.\n                Context:\n                {ctx}\n\n                Problem:\n                {problem}\n\n                Provide a concise final answer only (no long explanation). If the answer is a number, return the number alone.\n            \"\"\").strip()\n        else:\n            # simple template\n            prompt = textwrap.dedent(f\"\"\"\n                Problem:\n                {problem}\n\n                Provide a concise final answer only (no long explanation). If the answer is a number, return the number alone.\n            \"\"\").strip()\n\n        # compactar espaços em excesso\n        prompt = \"\\n\".join([line.rstrip() for line in prompt.splitlines() if line.strip() != \"\"])\n        return prompt\n\n    globals()['prepare_test_prompt'] = prepare_test_prompt\n    print(\"prepare_test_prompt definida com sucesso (fallback seguro).\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-08T08:52:16.319386Z","iopub.execute_input":"2026-03-08T08:52:16.319878Z","iopub.status.idle":"2026-03-08T08:52:16.324339Z","shell.execute_reply.started":"2026-03-08T08:52:16.319860Z","shell.execute_reply":"2026-03-08T08:52:16.323963Z"}},"outputs":[{"name":"stdout","text":"prepare_test_prompt definida com sucesso (fallback seguro).\n","output_type":"stream"}],"execution_count":13},{"id":"648e9718-b237-4972-851b-6f6e8dddab9c","cell_type":"code","source":"import re\nimport csv\nimport requests\nfrom pathlib import Path\nfrom urllib.parse import quote\nfrom functools import lru_cache\n\n# Taxonomia matemática para enriquecer contexto por domínio\nDOMAIN_KB = {\n    \"number_theory\": {\n        \"keywords\": [\"prime\", \"integer\", \"divisible\", \"gcd\", \"lcm\", \"mod\", \"congruence\", \"divisor\", \"factor\"],\n        \"pages\": [\"Number_theory\", \"Prime_number\", \"Divisibility\", \"Modular_arithmetic\", \"Greatest_common_divisor\"]\n    },\n    \"algebra\": {\n        \"keywords\": [\"equation\", \"polynomial\", \"function\", \"sequence\", \"inequality\", \"root\", \"coefficient\"],\n        \"pages\": [\"Algebra\", \"Polynomial\", \"Function_(mathematics)\", \"Inequality_(mathematics)\"]\n    },\n    \"geometry\": {\n        \"keywords\": [\"triangle\", \"circle\", \"angle\", \"area\", \"perimeter\", \"acute\", \"parallel\", \"line\", \"point\"],\n        \"pages\": [\"Geometry\", \"Triangle\", \"Circle\", \"Pythagorean_theorem\", \"Angle\"]\n    },\n    \"combinatorics\": {\n        \"keywords\": [\"permutation\", \"combination\", \"tournament\", \"count\", \"arrangement\", \"choose\", \"graph\"],\n        \"pages\": [\"Combinatorics\", \"Permutation\", \"Combination\", \"Graph_theory\", \"Pigeonhole_principle\"]\n    },\n    \"probability\": {\n        \"keywords\": [\"probability\", \"expected\", \"random\", \"event\", \"distribution\"],\n        \"pages\": [\"Probability\", \"Expected_value\", \"Random_variable\", \"Conditional_probability\"]\n    }\n}\n\nWIKI_HEADERS = {\n    \"User-Agent\": \"AIMO3-Context/1.0 (Kaggle notebook; educational use)\",\n    \"Accept\": \"application/json\"\n}\n\ndef detect_domains(problem_text: str, top_k: int = 2):\n    txt = (problem_text or \"\").lower()\n    scored = []\n    for domain, spec in DOMAIN_KB.items():\n        score = sum(1 for kw in spec[\"keywords\"] if kw in txt)\n        if score > 0:\n            scored.append((domain, score))\n    scored.sort(key=lambda x: x[1], reverse=True)\n    return [d for d, _ in scored[:top_k]] if scored else [\"algebra\"]\n\n@lru_cache(maxsize=512)\ndef wikipedia_summary(page_name: str):\n    url = f\"https://en.wikipedia.org/api/rest_v1/page/summary/{quote(page_name)}\"\n    try:\n        r = requests.get(url, headers=WIKI_HEADERS, timeout=12)\n        if r.status_code == 200:\n            j = r.json()\n            return {\n                \"title\": j.get(\"title\", page_name),\n                \"extract\": (j.get(\"extract\") or \"\").strip(),\n                \"source\": \"wikipedia_public\"\n            }\n    except Exception:\n        pass\n    return None\n\ndef wikimedia_on_demand_search(query: str, limit: int = 2):\n    \"\"\"\n    Tenta Wikimedia Enterprise se wme_session existir;\n    se não, retorna [] e o pipeline cai no fallback Wikipedia.\n    \"\"\"\n    session = globals().get(\"wme_session\")\n    if not session:\n        return []\n\n    endpoints = [\n        \"https://on-demand.wikimedia.org/v1/articles/search\",\n        \"https://api.enterprise.wikimedia.com/v2/articles/search\"\n    ]\n\n    for endpoint in endpoints:\n        try:\n            resp = session.get(endpoint, params={\"q\": query, \"limit\": limit}, timeout=10)\n            if resp.status_code == 200 and \"application/json\" in resp.headers.get(\"Content-Type\", \"\"):\n                data = resp.json()\n                arts = data.get(\"articles\", []) if isinstance(data, dict) else