Z"},"trusted":true},"outputs":[],"execution_count":5},{"id":"55963f73","cell_type":"code","source":"class ResponseParser:\n    def __init__(self, config: Dict):\n        self.patterns = [\n            (r'ANSWER\\s*:\\s*(-?\\d+)', 'direct'),\n            (r'answer\\s+is\\s*(-?\\d+)', 'phrase'),\n            (r'final answer.*?(-?\\d+)', 'context'),\n        ]\n        self.valid_range = config.get('answer_range', (0, 99999))\n\n    def extract(self, response: str, return_confidence=False) -> Optional[int]:\n        \"\"\"Extract with confidence score\"\"\"\n        answers = []\n        for pattern, method in self.patterns:\n            match = re.search(pattern, response, re.IGNORECASE)\n            if match:\n                ans = int(match.group(1))\n                if self._is_valid(ans):\n                    answers.append({'answer': ans, 'method': method, 'confidence': 0.9})\n\n        if answers:\n            best = max(answers, key=lambda x: x['confidence'])\n            return (best['answer'], best['confidence']) if return_confidence else best['answer']\n        return None\n\n    def _is_valid(self, ans: int) -> bool:\n        return self.valid_range[0] <= ans <= self.valid_range[1]","metadata":{"execution":{"iopub.status.busy":"2026-03-08T07:38:10.386601Z","iopub.execute_input":"2026-03-08T07:38:10.387370Z","iopub.status.idle":"2026-03-08T07:38:10.395677Z","shell.execute_reply.started":"2026-03-08T07:38:10.387328Z","shell.execute_reply":"2026-03-08T07:38:10.394714Z"},"trusted":true},"outputs":[],"execution_count":6},{"id":"4c5538cd","cell_type":"markdown","source":"## CÃ©lula 2: Carregar ConfiguraÃ§Ã£o e Dados","metadata":{}},{"id":"231c3fcd","cell_type":"code","source":"# STEP 2: Load Configuration\nprint(\"=\"*80)\nprint(\"STEP 2: LOADING CONFIGURATION\")\nprint(\"=\"*80)\n\n# Load config from YAML\ntry:\n    with open(PATHS['config'], 'r') as f:\n        config = yaml.safe_load(f)\n    print(f\"âœ“ Config loaded from {PATHS['config']}\")\nexcept FileNotF